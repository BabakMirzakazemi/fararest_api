{
  "DetailedErrors": true,
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AdminPanelSecurity": {
    "Authentication": {
      "AllowedRoles": [ "Admin", "SuperAdmin" ],
      "LoginPath": "/Auth/Login",
      "AccessDeniedPath": "/Auth/Login"
    },
    "OperationCatalog": {
      "Enabled": true,
      "AllowedServiceContracts": [ "IUserService", "IRoleService" ],
      "AllowedOperationKeys": [ "IUserService.All", "IUserService.AllByCursor", "IRoleService.GetRolesByUserAsync" ],
      "MaxParameterLength": 4000
    }
  }
}
