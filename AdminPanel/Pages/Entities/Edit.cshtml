@page "{entityName}/{key?}"
@model AdminPanel.Pages.Entities.EditModel
@{
    ViewData["Title"] = Model.IsCreate ? "ایجاد رکورد" : "ویرایش رکورد";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="h4 mb-1">@(Model.IsCreate ? "ایجاد رکورد جدید" : "ویرایش رکورد") - @Model.Entity.DisplayName</h1>
        <p class="text-muted mb-0">فرم پویا بر اساس ساختار موجودیت</p>
    </div>
    <a class="btn btn-outline-secondary" asp-page="/Entities/List" asp-route-entityName="@Model.Entity.Name">بازگشت</a>
</div>

@if (TempData["Error"] is string errorMessage)
{
    <div class="alert alert-danger white-space-pre">@errorMessage</div>
}

<div class="card shadow-sm">
    <div class="card-body">
        <form method="post" class="row g-3">
            @foreach (var property in Model.Entity.EditableProperties)
            {
                var effectiveType = Nullable.GetUnderlyingType(property.PropertyType) ?? property.PropertyType;
                <div class="col-12 col-md-6">
                    <label class="form-label" for="@property.Name">@property.DisplayName</label>
                    @if (Model.IsForeignKey(property))
                    {
                        <select class="form-select" id="@property.Name" name="@property.Name">
                            <option value="">انتخاب کنید</option>
                            @foreach (var option in Model.ForeignKeyOptions[property.Name])
                            {
                                if (option.Value == Model.GetValue(property))
                                {
                                    <option value="@option.Value" selected>@option.Label</option>
                                }
                                else
                                {
                                    <option value="@option.Value">@option.Label</option>
                                }
                            }
                        </select>
                    }
                    else if (effectiveType == typeof(bool))
                    {
                        var isChecked = Model.GetValue(property).Equals("true", StringComparison.OrdinalIgnoreCase) ||
                                        Model.GetValue(property).Equals("on", StringComparison.OrdinalIgnoreCase);
                        <div class="form-check mt-2">
                            <input class="form-check-input" type="checkbox" id="@property.Name" name="@property.Name" checked="@isChecked" />
                            <label class="form-check-label" for="@property.Name">فعال</label>
                        </div>
                    }
                    else if (property.IsEnum)
                    {
                        <select class="form-select" id="@property.Name" name="@property.Name">
                            <option value="">انتخاب کنید</option>
                            @foreach (var enumValue in Enum.GetNames(effectiveType))
                            {
                                if (enumValue == Model.GetValue(property))
                                {
                                    <option value="@enumValue" selected>@enumValue</option>
                                }
                                else
                                {
                                    <option value="@enumValue">@enumValue</option>
                                }
                            }
                        </select>
                    }
                    else if (effectiveType == typeof(DateTime) || effectiveType == typeof(DateTimeOffset))
                    {
                        <input class="form-control" id="@property.Name" name="@property.Name" type="datetime-local" value="@Model.GetValue(property)" />
                    }
                    else if (effectiveType == typeof(int) || effectiveType == typeof(long) || effectiveType == typeof(decimal) || effectiveType == typeof(float) || effectiveType == typeof(double))
                    {
                        <input class="form-control" id="@property.Name" name="@property.Name" type="number" step="any" value="@Model.GetValue(property)" />
                    }
                    else
                    {
                        <input class="form-control" id="@property.Name" name="@property.Name" value="@Model.GetValue(property)" />
                    }
                    @if (property.IsRequired)
                    {
                        <small class="text-danger">الزامی</small>
                    }
                </div>
            }
            <div class="col-12">
                <button class="btn btn-primary" type="submit">ذخیره</button>
            </div>
        </form>
    </div>
</div>
